AUTOFLOW_PORT=8765
LLM_PROVIDER=gemini
LLM_API_KEYS=
LLM_MODEL=gemini-3.1-flash-lite
WHISPER_MODEL=base

# Browser automation
# Optional: use Browser Use's hosted model/browser when BROWSER_USE_API_KEY is set.
BROWSER_USE_API_KEY=
BROWSER_LLM_PROVIDER=
BROWSER_USE_MODEL=bu-latest
BROWSER_USE_CLOUD=false
BROWSER_HEADLESS=false
BROWSER_KEEP_ALIVE=false
BROWSER_MAX_STEPS=100
BROWSER_MAX_ACTIONS_PER_STEP=3
BROWSER_MAX_FAILURES=2
BROWSER_PAGE_EXTRACTION_MODEL=gemini-flash-lite-latest
